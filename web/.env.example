# --- Local (default) ---
DATABASE_URL="file:./dev.db"

# --- Auth (required in production) ---
AUTH_SECRET="generate-a-long-random-string-for-production"

# --- Email verification ---
# Local testing: keep this true to show the code on screen (skips Resend).
SHOW_DEV_CODE=true
# Production: verify your domain at https://resend.com/domains then set:
# RESEND_API_KEY="re_xxxx"
# EMAIL_FROM="Moneybag <hello@yourdomain.com>"
RESEND_API_KEY=""
EMAIL_FROM="Moneybag <onboarding@resend.dev>"

# --- Trial & subscription ---
TRIAL_DAYS=2
SUBSCRIPTION_DAYS=30
ALLOW_DEMO_SUBSCRIPTION=true

# --- Vercel + Neon (free production) ---
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
