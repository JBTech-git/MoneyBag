# --- Local (default) ---
DATABASE_URL="file:./dev.db"

# --- Auth (required in production) ---
AUTH_SECRET="generate-a-long-random-string-for-production"

# --- Email verification ---
SHOW_DEV_CODE=true

# --- Email (production) — use SMTP or Resend (SMTP is tried first) ---

# Gmail SMTP (recommended without a custom domain; use a Google App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="info.mnybag@gmail.com"
SMTP_PASS="your-google-app-password"
EMAIL_FROM="Moneybag <info.mnybag@gmail.com>"

# Resend (optional fallback if SMTP_* is not set)
RESEND_API_KEY=""
# Sender — must be Resend sandbox OR your verified domain (NOT @gmail.com)
# EMAIL_FROM="Moneybag <onboarding@resend.dev>"

# Your support / reply-to address (can be Gmail)
EMAIL_REPLY_TO="info.mnybag@gmail.com"
SUPPORT_EMAIL="info.mnybag@gmail.com"

# --- Trial & subscription ---
TRIAL_DAYS=2
SUBSCRIPTION_DAYS=30
SUBSCRIPTION_PRICE_LABEL="₹99/month"
ALLOW_DEMO_SUBSCRIPTION=true

# --- Vercel: set these in Environment Variables (not in GitHub) ---
