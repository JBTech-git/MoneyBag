# --- Database (Neon Postgres in production) ---
DATABASE_URL="postgresql://USER:PASS@HOST/db?sslmode=require"

# --- Auth (required in production — use a long random secret) ---
AUTH_SECRET="generate-a-long-random-string-for-production"

# --- Email verification ---
# NEVER set SHOW_DEV_CODE=true in production (OTP will not be returned in prod anyway)
SHOW_DEV_CODE=false
# Local-only: EMAIL_CODE_FALLBACK=true shows code on screen if email fails (ignored in production)

# --- Email (production) — use SMTP or Resend (SMTP is tried first) ---

# Gmail SMTP (recommended without a custom domain; use a Google App Password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="info.mnybag@gmail.com"
SMTP_PASS="your-google-app-password"
EMAIL_FROM="Moneybag <info.mnybag@gmail.com>"

# Resend (optional fallback if SMTP_* is not set)
RESEND_API_KEY=""
# EMAIL_FROM="Moneybag <onboarding@resend.dev>"

EMAIL_REPLY_TO="info.mnybag@gmail.com"
SUPPORT_EMAIL="info.mnybag@gmail.com"

# Optional public URL used in admin notification emails
# APP_URL="https://money-bag-five.vercel.app"

# Trial, price, PhonePe, auto-activate:
# set ONLY in Super Admin → Subscription & PhonePe
# Keep Auto-activate OFF and Demo subscribe OFF for real payments

# --- Super Admin ---
SUPER_ADMIN_EMAILS="you@gmail.com"

# --- Moneybag Insights (server-side AI; keep provider private) ---
# API key from your AI provider dashboard — never expose to the client
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# --- Vercel: set these in Environment Variables (not in GitHub) ---
