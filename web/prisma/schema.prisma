generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?   @map("password_hash")
  name               String    @default("")
  isAdmin            Boolean   @default(false) @map("is_admin")
  disabledAt         DateTime? @map("disabled_at")
  trialStartedAt     DateTime  @default(now()) @map("trial_started_at")
  trialEndsAt        DateTime  @map("trial_ends_at")
  subscriptionStatus String    @default("trial") @map("subscription_status")
  subscriptionEndsAt DateTime? @map("subscription_ends_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  settings      AppSettings?
  accounts      Account[]
  incomes       Income[]
  expenses      Expense[]
  transactions  Transaction[]
  recurringRules RecurringRule[]
  quickTemplates QuickTemplate[]
  paymentClaims  PaymentClaim[]

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("email_verifications")
}

model Account {
  id             Int           @id @default(autoincrement())
  userId         String        @map("user_id")
  name           String
  accountType    String        @default("cash") @map("account_type")
  initialBalance Decimal       @default(0) @map("initial_balance")
  color          String        @default("")
  isDefault      Boolean       @default(false) @map("is_default")
  includeInTotal Boolean       @default(true) @map("include_in_total")
  sortOrder      Int           @default(0) @map("sort_order")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes        Income[]
  expenses       Expense[]
  transactions   Transaction[] @relation("TxnFromAccount")
  transfersIn    Transaction[] @relation("TxnToAccount")
  recurringRules RecurringRule[]
  quickTemplates QuickTemplate[]

  @@index([userId])
  @@map("accounts")
}

model Income {
  id           Int           @id @default(autoincrement())
  userId       String        @map("user_id")
  sourceName   String        @map("source_name")
  amount       Decimal
  accountId    Int           @map("account_id")
  periodYear   Int           @map("period_year")
  periodMonth  Int           @map("period_month")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@index([periodYear, periodMonth])
  @@map("incomes")
}

model Expense {
  id              Int           @id @default(autoincrement())
  userId          String        @map("user_id")
  categoryName    String        @map("category_name")
  budgetedAmount  Decimal       @map("budgeted_amount")
  actualAmount    Decimal       @default(0) @map("actual_amount")
  isPaid          Boolean       @default(false) @map("is_paid")
  accountId       Int           @map("account_id")
  periodYear      Int           @map("period_year")
  periodMonth     Int           @map("period_month")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@index([userId])
  @@index([periodYear, periodMonth])
  @@index([isPaid])
  @@map("expenses")
}

model Transaction {
  id              Int      @id @default(autoincrement())
  userId          String   @map("user_id")
  transactionType String   @map("transaction_type")
  categoryName    String   @map("category_name")
  amount          Decimal
  memo            String   @default("")
  accountId       Int      @map("account_id")
  toAccountId     Int?     @map("to_account_id")
  transactionDate DateTime @map("transaction_date")
  linkedIncomeId  Int?     @map("linked_income_id")
  linkedExpenseId Int?     @map("linked_expense_id")
  fromBudget      Boolean  @default(false) @map("from_budget")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account  @relation("TxnFromAccount", fields: [accountId], references: [id], onDelete: Cascade)
  toAccount       Account? @relation("TxnToAccount", fields: [toAccountId], references: [id], onDelete: SetNull)
  linkedIncome    Income?  @relation(fields: [linkedIncomeId], references: [id], onDelete: SetNull)
  linkedExpense   Expense? @relation(fields: [linkedExpenseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([transactionDate])
  @@index([transactionType])
  @@index([toAccountId])
  @@map("transactions")
}

model RecurringRule {
  id              Int       @id @default(autoincrement())
  userId          String    @map("user_id")
  transactionType String    @map("transaction_type")
  categoryName    String    @map("category_name")
  amount          Decimal
  memo            String    @default("")
  accountId       Int       @map("account_id")
  toAccountId     Int?      @map("to_account_id")
  frequency       String    @default("monthly")
  nextRunAt       DateTime  @map("next_run_at")
  lastRunAt       DateTime? @map("last_run_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextRunAt])
  @@map("recurring_rules")
}

model QuickTemplate {
  id              Int      @id @default(autoincrement())
  userId          String   @map("user_id")
  label           String
  transactionType String   @map("transaction_type")
  categoryName    String   @map("category_name")
  amount          Decimal  @default(0)
  memo            String   @default("")
  accountId       Int?     @map("account_id")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("quick_templates")
}

model PaymentClaim {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  amountLabel  String    @default("") @map("amount_label")
  utr          String    @default("")
  note         String    @default("")
  proofData    String    @default("") @map("proof_data")
  status       String    @default("pending")
  reviewNote   String    @default("") @map("review_note")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewedById String?   @map("reviewed_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@map("payment_claims")
}

model AppSettings {
  id                   Int      @id @default(autoincrement())
  userId               String   @unique @map("user_id")
  displayName          String   @default("") @map("display_name")
  currencyCode         String   @default("INR") @map("currency_code")
  currencySymbol       String   @default("₹") @map("currency_symbol")
  currencyPosition     String   @default("before") @map("currency_position")
  theme                String   @default("light")
  appMode              String   @default("daily") @map("app_mode")
  showZeroBalanceBadge Boolean  @default(true) @map("show_zero_balance_badge")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("app_settings")
}

// Singleton platform settings (id = 1). Super admin edits from /admin.
model SiteConfig {
  id                    Int      @id @default(1)
  trialDays             Int      @default(30) @map("trial_days")
  subscriptionDays      Int      @default(30) @map("subscription_days")
  priceLabel            String   @default("₹99/month") @map("price_label")
  allowDemoSubscription Boolean  @default(false) @map("allow_demo_subscription")
  phonepeEnabled        Boolean  @default(true) @map("phonepe_enabled")
  phonepeUpiId          String   @default("") @map("phonepe_upi_id")
  phonepeQrImage        String   @default("/payments/phonepe-qr.svg") @map("phonepe_qr_image")
  phonepeQrData         String   @default("") @map("phonepe_qr_data")
  paymentAutoActivate   Boolean  @default(false) @map("payment_auto_activate")
  phonepeInstructions   String   @default("") @map("phonepe_instructions")
  appUrl                String   @default("") @map("app_url")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}
